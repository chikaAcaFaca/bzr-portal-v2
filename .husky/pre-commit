#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

echo "🔍 Running pre-commit checks..."
echo ""

# Backend lint
echo "📋 Backend: Running ESLint..."
cd backend && npm run lint || exit 1
echo "✅ Backend lint passed"
echo ""

# Backend tests
echo "🧪 Backend: Running tests..."
npm run test -- --run || exit 1
echo "✅ Backend tests passed"
echo ""

# Note: Production frontend is bzr-savetnik/ (Next.js), not frontend/ (legacy Vite).
# Frontend checks run via bzr-savetnik's own build pipeline.

echo "✨ All pre-commit checks passed! Ready to commit."
